// Firestore security rules for the Mc Racking site.
// Paste this into: Firebase Console → Firestore Database → Rules → Publish

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /parts/{partId}       { allow read, write: if true; }
    match /invoices/{invId}     { allow read, write: if true; }
    match /meta/{docId}         { allow read, write: if true; }
    match /settings/{docId}     { allow read, write: if true; }
    match /audit_log/{entryId}  { allow read, write: if true; }
    match /deletions/{entryId}  { allow read, write: if true; }
  }
}
